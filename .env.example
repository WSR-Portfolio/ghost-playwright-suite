# Copy this file to .env and fill in real values. .env is gitignored — never commit it.
# In CI these are provided as GitHub Actions secrets, not from a file.

# --- Ghost test target ---
GHOST_URL=https://ghost.example.com
# Admin API key in {id}:{secret} form — used to mint a short-lived JWT per request
GHOST_ADMIN_API_KEY=your_admin_api_key_id:your_admin_api_key_secret
# Content API key — used as a ?key= query param (no JWT)
GHOST_CONTENT_API_KEY=your_content_api_key
# Staff/admin login used by the Admin UI persona tests
GHOST_ADMIN_EMAIL=admin@example.com
GHOST_ADMIN_PASSWORD=your_admin_password

# --- Mailpit (magic-link / 2FA email intercept) ---
# Reachable on the same network as Ghost; tests read magic links + 2FA codes from its API
MAILPIT_URL=http://10.0.0.0:8025

# --- Brute-table reset (optional; see docs/decisions.md ADR §11) ---
# global-setup.ts clears Ghost's express-brute rate-limit table before each run.
# Optional: if these are unset, global-setup logs a warning and no-ops (the suite still runs;
# the tuned spam config protects a single run). Use a DB user scoped to DELETE on `brute` only.
# In CI, DB_HOST must reach MySQL from inside the runner container — e.g. the MySQL
# container name on a shared Docker network, not 127.0.0.1.
DB_HOST=ghost-db-container-name
DB_PORT=3306
DB_NAME=ghost
DB_USER=your_brute_reset_db_user
DB_PASSWORD=your_brute_reset_db_password
